    <worksheet name='Treatment Deficit Difference'>
      <table>
        <view>
          <datasources>
            <datasource caption='dim_players' name='federated.1hu53nm00g7bqr1ao2nx40i76p9x' />
          </datasources>
          <datasource-dependencies datasource='federated.1hu53nm00g7bqr1ao2nx40i76p9x'>
            <column caption='Treatment Deficit vs Control %&quot;' datatype='real' name='[Calculation_0997812225732613]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNTD(IF [experiment_group] = &quot;Treatment&quot; THEN [player_id] END) -&#13;&#10;  COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END))&#13;&#10;  /&#13;&#10;  COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END)' />
            </column>
            <column caption='Experiment Group' datatype='string' name='[experiment_group]' role='dimension' type='nominal' />
            <column-instance column='[experiment_group]' derivation='None' name='[none:experiment_group:nk]' pivot='key' type='nominal' />
            <column-instance column='[spend_segment]' derivation='None' name='[none:spend_segment:nk]' pivot='key' type='nominal' />
            <column caption='Player Id' datatype='integer' name='[player_id]' role='dimension' type='ordinal' />
            <column caption='Spend Segment' datatype='string' name='[spend_segment]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0997812225732613]' derivation='User' name='[usr:Calculation_0997812225732613:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1hu53nm00g7bqr1ao2nx40i76p9x].[none:experiment_group:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:experiment_group:nk]' member='&quot;Control&quot;' />
              <groupfilter function='member' level='[none:experiment_group:nk]' member='&quot;Treatment&quot;' />
            </groupfilter>
          </filter>
          <slices>
            <column>[federated.1hu53nm00g7bqr1ao2nx40i76p9x].[none:experiment_group:nk]</column>
          </slices>
          <aggregation value='true' />
