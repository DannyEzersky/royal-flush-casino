      <aliases enabled='yes' />
      <column caption='ARPU' datatype='real' name='[Calculation_0114629203947521]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_revenue]) / COUNTD([player_id])' />
      </column>
      <column caption='Payer  Rate' datatype='real' name='[Calculation_0114629205827588]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [total_revenue] &gt; 0 THEN [player_id] END)&#13;&#10;  /&#13;&#10;  COUNTD(IF [last_session_date] &gt;= DATEADD(&apos;day&apos;, -14, {MAX([last_session_date])}) THEN [player_id] END)' />
      </column>
      <column caption='Active Users' datatype='integer' name='[Calculation_0114629219422217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;      IF [last_session_date] &gt;= DATEADD(&apos;day&apos;, -14, {MAX([last_session_date])})&#13;&#10;      THEN [player_id] END&#13;&#10;  )' />
      </column>
      <column caption='Treatment Deficit vs Control %&quot;' datatype='real' name='[Calculation_0997812225732613]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNTD(IF [experiment_group] = &quot;Treatment&quot; THEN [player_id] END) -&#13;&#10;  COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END))&#13;&#10;  /&#13;&#10;  COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END)' />
      </column>
