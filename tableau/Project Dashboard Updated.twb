      <aliases enabled='yes' />
      <column caption='ARPDAU' datatype='real' name='[Calculation_0114629203120128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({FIXED [session_date] : SUM([daily_revenue]) / COUNTD([player_id])})' />
      </column>
      <column caption='Avg DAU' datatype='real' name='[Calculation_0114629208207365]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({FIXED [session_date] : COUNTD([player_id])})' />
      </column>
      <column caption='Avg Spins' datatype='real' name='[Calculation_0114629208731654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([spin_count])' />
      </column>
      <column caption='Avg MAU' datatype='real' name='[Calculation_0114629217816583]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({FIXED DATETRUNC(&apos;month&apos;, [session_date]) : COUNTD([player_id])})' />
      </column>
      <column caption='DAU/MAU Ratio' datatype='real' name='[Calculation_0114629218037768]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0114629208207365] / [Calculation_0114629217816583]' />
      </column>
      <column caption='ARPU' datatype='real' name='[Calculation_0997812175118337]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([daily_revenue]) / COUNTD([player_id])' />
      </column>
      <column caption='Lift %' datatype='real' name='[Calculation_0997812176175106]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [experiment_group] = &quot;Treatment&quot; THEN [daily_revenue] END) /&#13;&#10;  COUNTD(IF [experiment_group] = &quot;Treatment&quot; THEN [player_id] END)&#13;&#10;  -&#13;&#10;  SUM(IF [experiment_group] = &quot;Control&quot; THEN [daily_revenue] END) /&#13;&#10;  COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END))&#13;&#10;  /&#13;&#10;  (SUM(IF [experiment_group] = &quot;Control&quot; THEN [daily_revenue] END) /&#13;&#10;  COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END))' />
      </column>
      <column caption='ARPU Lift % by Segment' datatype='real' name='[Calculation_0997812220121092]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;    {FIXED [spend_segment] : SUM(IF [experiment_group] = &quot;Treatment&quot; THEN [daily_revenue] END)} /&#13;&#10;    {FIXED [spend_segment] : COUNTD(IF [experiment_group] = &quot;Treatment&quot; THEN [player_id] END)}&#13;&#10;    -&#13;&#10;    {FIXED [spend_segment] : SUM(IF [experiment_group] = &quot;Control&quot; THEN [daily_revenue] END)} /&#13;&#10;    {FIXED [spend_segment] : COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END)}&#13;&#10;  )&#13;&#10;  /&#13;&#10;  (&#13;&#10;    {FIXED [spend_segment] : SUM(IF [experiment_group] = &quot;Control&quot; THEN [daily_revenue] END)} /&#13;&#10;    {FIXED [spend_segment] : COUNTD(IF [experiment_group] = &quot;Control&quot; THEN [player_id] END)}&#13;&#10;  )' />
      </column>
      <column caption='D1 Retention' datatype='real' name='[Calculation_0997812231651334]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF DATEDIFF(&apos;day&apos;, [install_date], [session_date]) = 1&#13;&#10;         THEN [player_id] END)&#13;&#10;  / COUNTD([player_id])' />
      </column>
      <column caption='D7 Retention' datatype='real' name='[Calculation_0997812231827463]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF DATEDIFF(&apos;day&apos;, [install_date], [session_date]) = 7&#13;&#10;         THEN [player_id] END)&#13;&#10;  / COUNTD([player_id])' />
      </column>
      <column caption='D30 Retention' datatype='real' name='[Calculation_0997812231954440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF DATEDIFF(&apos;day&apos;, [install_date], [session_date]) = 30&#13;&#10;         THEN [player_id] END)&#13;&#10;  / COUNTD([player_id])' />
      </column>
