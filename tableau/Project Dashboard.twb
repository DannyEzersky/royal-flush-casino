      </column>
      <column caption='Paying Players' datatype='integer' name='[Calculation_0505505149956099]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF NOT ISNULL([first_purchase_date]) THEN [player_id] END)' />
