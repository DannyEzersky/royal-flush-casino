      <column caption='ARPU' datatype='real' default-format='C1033%' name='[Calculation_0505505153216517]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([daily_revenue]) / COUNTD([player_id])' />
      </column>
      <column caption='DAU' datatype='real' name='[Calculation_0505505154899974]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({ FIXED [session_date] : COUNTD([player_id]) })' />
      </column>
      <column caption='Royal Spin Launch' datatype='string' name='[Calculation_0505505159417863]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [session_date] &lt; #2024-07-01# THEN &quot;Pre-Launch&quot; ELSE &quot;Post-Launch&quot; END' />
      </column>
      <column caption='Churn Date' datatype='datetime' name='[Calculation_0505505164193800]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;day&apos;, 7, { FIXED [player_id] : MAX([session_date]) })' />
      </column>
      <column caption='Is Valid Max Churn Date' datatype='boolean' name='[Calculation_0505505164918793]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0505505164193800] &lt;= { MAX([session_date]) }' />
      </column>
