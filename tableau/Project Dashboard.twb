      <column caption='Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_0505505150545924]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF NOT ISNULL([first_purchase_date]) THEN [player_id] END) / COUNTD([player_id])' />
